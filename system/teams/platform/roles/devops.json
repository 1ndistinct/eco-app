{
  "name": "platform-devops",
  "description": "Devops delivery phases for deploy and infrastructure changes.",
  "phases": [
    {
      "name": "deploy",
      "description": "Run deploy or ci when delivery tooling or deployment files change.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["deploy/**", "Taskfile.yml", "Tiltfile", "services/app-shell/Dockerfile", "services/app-todo/Dockerfile", "services/web/Dockerfile", "services/web/nginx/**"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["deploy", "ci"]
        },
        {
          "type": "task_target_prefix_exists",
          "match_any": ["probe:"]
        }
      ],
      "receipts": [
        {
          "name": "deploy",
          "type": "command_ran",
          "match_any": ["task ci", "task deploy", "tilt ci", "helm upgrade --install", "kubectl apply"]
        }
      ]
    },
    {
      "name": "probe",
      "description": "Probe the deployed system after infrastructure or delivery changes.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["deploy/**", "Taskfile.yml", "Tiltfile", "services/app-shell/Dockerfile", "services/app-todo/Dockerfile", "services/web/Dockerfile", "services/web/nginx/**"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["deploy", "ci"]
        },
        {
          "type": "task_target_prefix_exists",
          "match_any": ["probe:"]
        }
      ],
      "receipts": [
        {
          "name": "probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:", "curl ", "wget ", "http://", "https://"]
        }
      ]
    },
    {
      "name": "external-probe",
      "description": "Validate the host-reachable frontend and backend contract when external probe targets exist.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["deploy/**", "Taskfile.yml", "Tiltfile", "services/app-shell/Dockerfile", "services/app-todo/Dockerfile", "services/web/Dockerfile", "services/web/nginx/**"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["probe:app:external", "probe:web:external"]
        }
      ],
      "receipts": [
        {
          "name": "external backend probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:app:external", "/api/healthz"]
        },
        {
          "name": "external frontend probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:web:external", ".localhost/"]
        }
      ]
    },
    {
      "name": "browser-e2e",
      "description": "Run browser-level validation against the deployed app when a Playwright-style target exists.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["deploy/**", "Taskfile.yml", "Tiltfile", "services/app-shell/Dockerfile", "services/app-todo/Dockerfile", "services/web/Dockerfile", "services/web/nginx/**"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["test:e2e"]
        }
      ],
      "receipts": [
        {
          "name": "browser e2e",
          "type": "command_ran",
          "match_any": ["task test:e2e", "playwright test"]
        }
      ]
    },
    {
      "name": "cleanup",
      "description": "Tear the deployed environment down after validation when cleanup targets exist.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["deploy/**", "Taskfile.yml", "Tiltfile", "services/app-shell/Dockerfile", "services/app-todo/Dockerfile", "services/web/Dockerfile", "services/web/nginx/**"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["cleanup", "down"]
        }
      ],
      "receipts": [
        {
          "name": "cleanup",
          "type": "command_ran",
          "match_any": ["task ci", "task cleanup", "task down", "helm uninstall"]
        }
      ]
    }
  ]
}
