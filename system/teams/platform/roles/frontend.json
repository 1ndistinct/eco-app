{
  "name": "platform-frontend",
  "description": "Frontend delivery phases for deployable UI changes.",
  "phases": [
    {
      "name": "implement",
      "description": "Frontend implementation tasks must change shipped UI code, not only notes or supporting docs.",
      "required": true,
      "receipts": [
        {
          "name": "frontend code changed",
          "type": "changed_file_matches",
          "match_any": ["services/web/src/**", "services/web/index.html"]
        }
      ]
    },
    {
      "name": "tests-updated",
      "description": "Frontend behavior changes must update or add automated UI tests alongside the implementation.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/src/**", "services/web/index.html"]
        }
      ],
      "receipts": [
        {
          "name": "frontend tests changed",
          "type": "changed_file_matches",
          "match_any": ["services/web/src/**/*.test.*", "services/web/src/**/*.spec.*", "services/web/src/**/__tests__/**"]
        }
      ]
    },
    {
      "name": "deploy",
      "description": "Run deploy or ci when frontend changes affect deployable behavior and deploy targets exist.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/**", "deploy/**", "Taskfile.yml", "Tiltfile"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["deploy", "ci"]
        },
        {
          "type": "task_target_prefix_exists",
          "match_any": ["probe:"]
        }
      ],
      "receipts": [
        {
          "name": "deploy",
          "type": "command_ran",
          "match_any": ["task ci", "task deploy", "tilt ci", "helm upgrade --install", "kubectl apply"]
        }
      ]
    },
    {
      "name": "probe",
      "description": "Probe the deployed frontend or run a small functional request after deploy.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/**", "deploy/**", "Taskfile.yml", "Tiltfile"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["deploy", "ci"]
        },
        {
          "type": "task_target_prefix_exists",
          "match_any": ["probe:"]
        }
      ],
      "receipts": [
        {
          "name": "probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:", "curl ", "wget ", "http://", "https://"]
        }
      ]
    },
    {
      "name": "external-probe",
      "description": "Validate the host-reachable frontend and backend contract when external probe targets exist.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/**", "deploy/**", "Taskfile.yml", "Tiltfile"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["probe:app:external", "probe:web:external"]
        }
      ],
      "receipts": [
        {
          "name": "external backend probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:app:external", "/api/healthz"]
        },
        {
          "name": "external frontend probe",
          "type": "command_ran",
          "match_any": ["task ci", "task probe:web:external", ".localhost/"]
        }
      ]
    },
    {
      "name": "browser-e2e",
      "description": "Run browser-level validation against the deployed app when a Playwright-style target exists.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/**", "deploy/**", "Taskfile.yml", "Tiltfile"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["test:e2e"]
        }
      ],
      "receipts": [
        {
          "name": "browser e2e",
          "type": "command_ran",
          "match_any": ["task test:e2e", "playwright test"]
        }
      ]
    },
    {
      "name": "cleanup",
      "description": "Tear the deployed environment down after validation when cleanup targets exist.",
      "required": true,
      "when": [
        {
          "type": "changed_file_matches",
          "match_any": ["services/web/**", "deploy/**", "Taskfile.yml", "Tiltfile"]
        },
        {
          "type": "task_target_exists",
          "match_any": ["cleanup", "down"]
        }
      ],
      "receipts": [
        {
          "name": "cleanup",
          "type": "command_ran",
          "match_any": ["task ci", "task cleanup", "task down", "helm uninstall"]
        }
      ]
    }
  ]
}
